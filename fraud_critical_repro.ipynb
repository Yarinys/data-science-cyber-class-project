    "print(f\"test : {X_test.shape[0]:,} rows  ({int(y_test.sum())} frauds)\")\n",
    "print(f\"fraud prevalence preserved -> train {y_train.mean():.4%} | test {y_test.mean():.4%}\")"
   ]
  },
