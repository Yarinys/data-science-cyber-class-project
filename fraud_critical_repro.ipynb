    {
     "output_type": "stream",
     "name": "stdout",
     "text": [
      "XGBoost PR-AUC: base 0.8717 -> with Hour + log_Amount 0.8692\ncreated-feature importance: Hour=0.0141, log_Amount=0.0000\n"
     ]
    }
   ],
   "source": [
    "from xgboost import XGBClassifier\n",
    "extra = pd.DataFrame({'Hour': (df['Time'] // 3600 % 24).astype(int),\n",
    "                      'log_Amount': np.log1p(df['Amount'])}, index=df.index)\n",
    "base_cols = [c for c in df.columns if c != 'Class']\n",
    "\n",
    "def xgb_prauc(features):\n",
    "    Xtr, Xte, ytr, yte = train_test_split(features, df['Class'], test_size=0.2,\n",
    "                                          stratify=df['Class'], random_state=SEED)\n",
    "    pw = (ytr == 0).sum() / (ytr == 1).sum()\n",
    "    m = XGBClassifier(n_estimators=120, max_depth=5, learning_rate=0.2, scale_pos_weight=pw,\n",
    "                      eval_metric='logloss', random_state=SEED).fit(Xtr, ytr)\n",
    "    return average_precision_score(yte, m.predict_proba(Xte)[:, 1]), m\n",
    "\n",
    "ap_base, _ = xgb_prauc(df[base_cols])\n",
    "ap_aug, m_aug = xgb_prauc(pd.concat([df[base_cols], extra], axis=1))\n",
    "imp = pd.Series(m_aug.feature_importances_, index=base_cols + ['Hour', 'log_Amount'])\n",
    "print(f'XGBoost PR-AUC: base {ap_base:.4f} -> with Hour + log_Amount {ap_aug:.4f}')\n",
    "print(f'created-feature importance: Hour={imp[\"Hour\"]:.4f}, log_Amount={imp[\"log_Amount\"]:.4f}')"
   ]
  },
